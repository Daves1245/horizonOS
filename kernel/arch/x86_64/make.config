KERNEL_ARCH_CFLAGS= -no-pie -mcmodel=kernel -fno-pic -fstack-protector -mstack-protector-guard=global -mno-red-zone -mno-sse -mno-mmx -mno-sse2 -mno-avx -msoft-float
KERNEL_ARCH_CPPFLAGS= -D__x86_64__ -I$(ARCHDIR)/include
KERNEL_ARCH_LDFLAGS=
KERNEL_ARCH_LIBS=

KERNEL_ARCH_OBJS=\
$(ARCHDIR)/boot/boot.o \
$(ARCHDIR)/drivers/tty.o \
$(ARCHDIR)/common/logger.o \
$(ARCHDIR)/interrupts/descriptor_tables.o \
$(ARCHDIR)/interrupts/gdt.o \
$(ARCHDIR)/interrupts/isr.o \
$(ARCHDIR)/interrupts/stack_protector.o \
$(ARCHDIR)/interrupts/common.o \
$(ARCHDIR)/interrupts/apic.o \
$(ARCHDIR)/memory/paging.o \
$(ARCHDIR)/asm/interrupt.o \
$(ARCHDIR)/asm/apic_asm.o
