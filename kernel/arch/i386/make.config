KERNEL_ARCH_CFLAGS=-mno-sse -mno-red-zone -mno-mmx -mno-sse2 -mno-3dnow -mno-avx -msoft-float -mno-80387
KERNEL_ARCH_CPPFLAGS= -I$(ARCHDIR)/common
KERNEL_ARCH_LDFLAGS=
KERNEL_ARCH_LIBS=

KERNEL_ARCH_OBJS=\
$(ARCHDIR)/boot/boot.o \
$(ARCHDIR)/drivers/tty.o \
$(ARCHDIR)/drivers/serial.o \
$(ARCHDIR)/drivers/timer.o \
$(ARCHDIR)/gdt/descriptor_tables.o \
$(ARCHDIR)/gdt/gdt.o \
$(ARCHDIR)/interrupts/interrupt.o \
$(ARCHDIR)/interrupts/isr.o \
$(ARCHDIR)/common/stack_protector.o \
$(ARCHDIR)/common/ctype.o \
$(ARCHDIR)/common/rand.o \
$(ARCHDIR)/memory/paging.o \
$(ARCHDIR)/apic/apic_asm.o \
../libc/string/string.o \
$(ARCHDIR)/drivers/keyboard/keyboard.o \
$(ARCHDIR)/drivers/shell/hush.o \
$(ARCHDIR)/drivers/shell/builtins/maze.o \
